# ── Required — all four must be set before running ────────────────────────────

# PostgreSQL connection string
# For Docker Compose: postgresql://postgres:<DB_PASSWORD>@db:5432/duluan
# For external DB:    postgresql://user:password@host:5432/duluan
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/duluan

# Better Auth signing secret — generate with: openssl rand -base64 32
# Must be at least 32 characters. Rotate this and all existing sessions invalidate.
BETTER_AUTH_SECRET=change-this-to-a-random-32-char-string-min-32-chars

# Public URL of this app (no trailing slash)
# Used by Better Auth for CORS and cookie domain validation.
BETTER_AUTH_URL=https://your-domain.com

# Game Master passcode (min 4 characters)
# GMs log in at /admin with this password.
GM_PASSWORD=your-secure-passcode

# ── Runtime defaults set in Dockerfile (override here if needed) ──────────────
# PORT=3000
# HOSTNAME=0.0.0.0
# NODE_ENV=production

# ── Deployment notes ──────────────────────────────────────────────────────────
# SSE (Server-Sent Events) uses an in-memory store — run exactly ONE container
# replica. Multiple replicas will NOT broadcast to each other.
# Swap lib/sse.ts to Redis pub/sub before scaling horizontally.

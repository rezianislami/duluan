# ── Required — set all of these before running ────────────────────────────────

# PostgreSQL connection string (use Supabase direct connection URL, port 5432)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Better Auth signing secret — generate with: openssl rand -base64 32
# Must be at least 32 characters. Rotate this and all existing sessions invalidate.
BETTER_AUTH_SECRET=change-this-to-a-random-32-char-string-min-32-chars

# Public URL of this app (no trailing slash)
# Vercel: set to your production URL after first deploy
BETTER_AUTH_URL=https://your-app.vercel.app

# Game Master passcode (min 4 characters)
GM_PASSWORD=your-secure-passcode

# ── Supabase Realtime (required for real-time game updates) ───────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Project URL (e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose to browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# ── Runtime defaults set in Dockerfile (override here if needed) ──────────────
# PORT=3000
# HOSTNAME=0.0.0.0
# NODE_ENV=production

# ── Deployment notes ──────────────────────────────────────────────────────────
# Real-time uses Supabase Realtime Broadcast — works on Vercel serverless.
# DATABASE_URL: use the "direct connection" (port 5432), not the pooler (port 6543),
# because Drizzle migrations require full Postgres feature support.
